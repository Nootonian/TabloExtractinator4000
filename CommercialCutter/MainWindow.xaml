<Window x:Class="CommercialCutter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Commercial Cutter" Width="900" Height="780" WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Window.Resources>
        <SolidColorBrush x:Key="Bg"        Color="#1E1E1E" />
        <SolidColorBrush x:Key="PanelBg"   Color="#252526" />
        <SolidColorBrush x:Key="ControlBg" Color="#2D2D30" />
        <SolidColorBrush x:Key="BorderCol" Color="#3F3F46" />
        <SolidColorBrush x:Key="Fg"        Color="#E0E0E0" />
        <SolidColorBrush x:Key="MutedFg"   Color="#9A9A9A" />
        <SolidColorBrush x:Key="Accent"    Color="#0E78D4" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
        </Style>
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource Bg}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}" />
            <Setter Property="CaretBrush" Value="{StaticResource Fg}" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BorderCol}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MutedFg}" />
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelBg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="16" Height="16" Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderCol}" BorderThickness="1" Margin="2">
                                <Path x:Name="Check" Data="M2,8 L6,12 L14,2" Stroke="{StaticResource Fg}" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Margin" Value="0,0,16,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Dot" Width="16" Height="16" Background="{StaticResource ControlBg}"
                                    BorderBrush="{StaticResource BorderCol}" BorderThickness="1" CornerRadius="8" Margin="2">
                                <Ellipse x:Name="Fill" Width="8" Height="8" Fill="{StaticResource Fg}" Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Fill" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Dot" Property="Background" Value="{StaticResource Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}" />
            <Setter Property="RowBackground" Value="{StaticResource PanelBg}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource ControlBg}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderCol}" />
            <Setter Property="HeadersVisibility" Value="Column" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource Fg}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="{StaticResource ControlBg}" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderCol}" />
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="{StaticResource Bg}" />
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="#5A5A5E" CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource PanelBg}" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Orientation="Vertical">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineDownCommand" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}" Margin="2,0" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="12" />
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track" Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.LineRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumb}" Margin="0,2" />
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16">

            <!-- Step 1: pick video -->
            <TextBlock Text="1. Choose the recording" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <DockPanel Margin="0,0,0,8">
                <Button DockPanel.Dock="Right" Content="Browse..." Width="90" Click="BrowseVideo_Click" />
                <TextBox x:Name="VideoPathBox" IsReadOnly="True" Margin="0,0,8,0" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock x:Name="VideoInfoText" Foreground="{StaticResource MutedFg}" Margin="0,0,0,16" />

            <!-- Step 2: select logo box -->
            <TextBlock Text="2. Mark the station logo bug" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="Pick a moment in the recording where the program (not a commercial) is on screen, then draw a tight box around the channel's logo bug. The tool watches that spot for the rest of the analysis." />
            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Left" Text="Sample at (seconds):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="SampleAtBox" Width="100" Text="" VerticalContentAlignment="Center" HorizontalAlignment="Left" />
            </DockPanel>
            <Button x:Name="SelectBoxButton" Content="Draw Logo Box..." Width="160" HorizontalAlignment="Left"
                    Click="SelectBox_Click" IsEnabled="False" Margin="0,0,0,8" />
            <TextBlock x:Name="BoxInfoText" Foreground="{StaticResource MutedFg}" Margin="0,0,0,16" />

            <!-- Step 3: catalog + analyze -->
            <TextBlock Text="3. Catalog and analyze" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="Samples the logo spot every N seconds. You can leave Expected program length blank — with Local adaptive mode and Refine cuts (below) both on, a safe built-in default is used automatically and doesn't need per-video tuning. Only fill this in if you already know the real length (e.g. from having cut this exact episode by hand before) and want a sanity check against it." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Sample interval (s):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="IntervalBox" DockPanel.Dock="Left" Width="60" Text="1" VerticalContentAlignment="Center" Margin="0,0,16,0" />
                <TextBlock DockPanel.Dock="Left" Text="Expected program length (min, optional):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="ExpectedLengthBox" DockPanel.Dock="Left" Width="60" Text="" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="A single fixed similarity cutoff assumes the logo-present baseline never drifts across the episode — it often does (different scenes partially defeat the logo mask even with the bug on screen), which can hide a real break whose dip isn't deep in absolute terms. Local adaptive mode classifies each moment relative to a rolling local baseline instead, and is what's been tuned and verified here — stick with it unless you have a specific reason to switch. Absolute threshold is really only worth trying if adaptive mode is clearly misbehaving on a particular recording (e.g. wildly over- or under-detecting) and you want a single fixed cutoff to reason about directly; there's no general guidance for what number to type in there, you'd be eyeballing the similarity chart after a run." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <RadioButton x:Name="AdaptiveModeRadio" DockPanel.Dock="Left" GroupName="DetectionMode" Content="Local adaptive (recommended)" IsChecked="True" Checked="DetectionMode_Changed" />
                <RadioButton x:Name="AbsoluteModeRadio" DockPanel.Dock="Left" GroupName="DetectionMode" Content="Absolute threshold" Checked="DetectionMode_Changed" />
            </DockPanel>
            <DockPanel x:Name="AdaptiveModePanel" Margin="0,0,0,8" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Max dip from local baseline (optional — leave blank for the default):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="AdaptiveDipBox" DockPanel.Dock="Left" Width="60" Text="" VerticalContentAlignment="Center" Margin="0,0,16,0" />
            </DockPanel>
            <DockPanel x:Name="AbsoluteModePanel" Margin="0,0,0,8" LastChildFill="False" Visibility="Collapsed">
                <TextBlock DockPanel.Dock="Left" Text="Manual threshold (optional):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="ThresholdBox" DockPanel.Dock="Left" Width="60" Text="" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="Commercial breaks are built from 15s/30s ad slots, so detected break lengths are rounded to the nearest ad-unit multiple below — this cleans up noisy boundary detection. Breaks shorter than the minimum are treated as false positives and dropped. Real breaks are almost always 2+ back-to-back spots, so 59s is a reasonable floor — anything shorter is more likely a misdetection than an actual single-spot break." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <TextBlock DockPanel.Dock="Left" Text="Ad unit length (s):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="AdUnitSecondsBox" DockPanel.Dock="Left" Width="60" Text="15" VerticalContentAlignment="Center" Margin="0,0,16,0" />
                <TextBlock DockPanel.Dock="Left" Text="Minimum break length (s):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="MinBreakSecondsBox" DockPanel.Dock="Left" Width="60" Text="59" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="The logo signal alone can land mid-fade. With this on (recommended — also enables black-bridge detection for breaks where the bug stays on screen the whole time, and is what the safe default dip above relies on), each cut point nudges onto the nearest black (or, failing that, silent) dip within the tolerance below, so the full fade-to-black/fade-up-from-black bumper stays with the program, not the ad. Requires an extra full decode pass. The default of 6s is fine for nearly everything — it only needs to comfortably cover the length of a typical fade, not the length of the break itself; raise it only if you see a cut consistently landing a few seconds short of a clean black frame." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <CheckBox x:Name="RefineTransitionsCheckBox" DockPanel.Dock="Left" Content="Refine cuts to black/silence dips" IsChecked="True" Margin="0,0,16,0" />
                <TextBlock DockPanel.Dock="Left" Text="Max nudge (s):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="MaxNudgeSecondsBox" DockPanel.Dock="Left" Width="60" Text="6" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="A network's own promos for its other shows usually keep that network's bug visible the whole time — so logo-absence can't see them the way it sees a real commercial. This looks for a black/silent cut near the very start/end of the recording instead, independent of the logo signal, and trims up to it. Requires the option above to be on." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <CheckBox x:Name="TrimEdgePromosCheckBox" DockPanel.Dock="Left" Content="Trim leading/trailing network promo" Margin="0,0,16,0" />
                <TextBlock DockPanel.Dock="Left" Text="Max promo length (s):" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="MaxPromoSecondsBox" DockPanel.Dock="Left" Width="60" Text="90" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="Mistakes go two ways: leaving a real ad in (annoying, costs you a few seconds at playback) or cutting real program (worse — you lose part of the episode). This makes the black-bridge detector demand stronger evidence before trusting a break where the bug stays visible the whole time, which only ever trades in one direction: it can miss more ads it would otherwise have caught, but verified across every episode tested so far, it never increases program wrongly cut. Worth turning on for unattended batch runs you won't review by hand." />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <CheckBox x:Name="FavorKeepingProgramCheckBox" DockPanel.Dock="Left" Content="Favor keeping program over removing every ad" Margin="0,0,16,0" />
            </DockPanel>
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <Button x:Name="AnalyzeButton" DockPanel.Dock="Left" Content="Run Analysis" Width="160"
                        Click="Analyze_Click" IsEnabled="False" />
                <Button x:Name="ExportDiagnosticsButton" DockPanel.Dock="Left" Content="Export Diagnostics..." Width="160"
                        Click="ExportDiagnostics_Click" IsEnabled="False" Margin="8,0,0,0" />
            </DockPanel>
            <TextBlock x:Name="AnalyzeInfoText" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4" />
            <TextBlock x:Name="ThresholdInfoText" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4" />
            <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderCol}" BorderThickness="1" Margin="0,0,0,16">
                <Canvas x:Name="SimilarityChart" Height="120" ClipToBounds="True" />
            </Border>

            <!-- Step 4: review + cut -->
            <TextBlock Text="4. Review segments and cut" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,4"
                       Text="AD = will be removed, PRG = will be kept. Untick/tick the box to fix any misdetected segment before cutting. The table on the right shows where each removed break's splice lands once cut, so you can scrub the finished video to that point and check the join." />
            <Grid HorizontalAlignment="Left" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Segments" FontWeight="Bold" Margin="0,0,0,2" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Cuts in the output file" FontWeight="Bold" Margin="0,0,0,2" />

                <DataGrid x:Name="SegmentsGrid" Grid.Row="1" Grid.Column="0" Height="220" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="False" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Start" Binding="{Binding Start}" IsReadOnly="True" Width="90" />
                        <DataGridTextColumn Header="End" Binding="{Binding End}" IsReadOnly="True" Width="90" />
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}" IsReadOnly="True" Width="90" />
                        <DataGridCheckBoxColumn Header="Is Commercial" Binding="{Binding IsCommercial, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid x:Name="CutMapGrid" Grid.Row="1" Grid.Column="2" Height="220" AutoGenerateColumns="False" CanUserAddRows="False"
                          IsReadOnly="True" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Output time" Binding="{Binding OutputPosition}" Width="90" />
                        <DataGridTextColumn Header="Removed (source)" Binding="{Binding RemovedRange}" Width="140" />
                        <DataGridTextColumn Header="Length" Binding="{Binding RemovedDuration}" Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
            <DockPanel Margin="0,0,0,8">
                <Button DockPanel.Dock="Right" Content="Browse..." Width="90" Click="BrowseOutput_Click" />
                <TextBlock DockPanel.Dock="Left" Text="Output file:" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="OutputPathBox" Margin="0,0,8,0" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock Text="Cut mode:" Margin="0,0,0,4" />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <RadioButton x:Name="FastCutRadio" DockPanel.Dock="Left" GroupName="CutMode" Content="Fast (stream copy)" Checked="CutMode_Changed" />
                <RadioButton x:Name="HybridCutRadio" DockPanel.Dock="Left" GroupName="CutMode" Content="Hybrid, snap within (s):" Checked="CutMode_Changed" />
                <TextBox x:Name="HybridToleranceBox" DockPanel.Dock="Left" Width="50" Text="3" VerticalContentAlignment="Center" Margin="0,0,16,0" />
                <RadioButton x:Name="ExactCutRadio" DockPanel.Dock="Left" GroupName="CutMode" Content="Exact (always re-encode)" IsChecked="True" Checked="CutMode_Changed" />
            </DockPanel>
            <TextBlock x:Name="CutModeInfoText" Foreground="{StaticResource MutedFg}" TextWrapping="Wrap" Margin="0,0,0,8" />
            <DockPanel Margin="0,0,0,8" LastChildFill="False">
                <Button x:Name="CutButton" DockPanel.Dock="Left" Content="Cut Video" Width="160" HorizontalAlignment="Left"
                        Click="Cut_Click" IsEnabled="False" />
                <TextBlock x:Name="NvencInfoText" DockPanel.Dock="Left" Foreground="{StaticResource MutedFg}"
                           VerticalAlignment="Center" Margin="12,0,0,0" />
            </DockPanel>

            <!-- Step 5: batch process a directory -->
            <TextBlock Text="5. Batch process a directory" FontWeight="Bold" FontSize="16" Margin="0,0,0,4" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="Once the logo box and analysis settings above are tuned on one episode, reuse them on every recording in a folder (and its subfolders) from the same show/channel." />
            <DockPanel Margin="0,0,0,8">
                <Button DockPanel.Dock="Right" Content="Browse..." Width="90" Click="BrowseBatchFolder_Click" />
                <TextBox x:Name="BatchFolderBox" IsReadOnly="True" Margin="0,0,8,0" VerticalContentAlignment="Center" />
            </DockPanel>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedFg}" Margin="0,0,0,8"
                       Text="If the folder mixes recordings that don't all have the same resolution or logo bug (e.g. a different show or channel mixed in), run Check Compatibility first — it samples a few frames per file and unticks anything that doesn't match, without running the full analysis on it." />
            <DataGrid x:Name="BatchGrid" Height="180" AutoGenerateColumns="False" CanUserAddRows="False"
                      Margin="0,0,0,8">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header="Include" Binding="{Binding Included}" Width="60" />
                    <DataGridTextColumn Header="File" Binding="{Binding RelativePath}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="280" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="CheckCompatibilityButton" Content="Check Compatibility" Width="160"
                        Click="CheckCompatibility_Click" IsEnabled="False" Margin="0,0,8,0" />
                <Button x:Name="StartBatchButton" Content="Start Batch" Width="160"
                        Click="StartBatch_Click" IsEnabled="False" />
            </StackPanel>
            <TextBlock x:Name="BatchInfoText" Foreground="{StaticResource MutedFg}" Margin="0,0,0,16" />

            <TextBlock Text="Status" FontWeight="Bold" Margin="0,8,0,4" />
            <TextBox x:Name="LogBox" Height="120" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" FontFamily="Consolas" />
        </StackPanel>
        </ScrollViewer>

        <!-- Footer: ffmpeg progress + abort -->
        <Border Grid.Row="1" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource BorderCol}"
                BorderThickness="0,1,0,0" Padding="16,10">
            <DockPanel>
                <Button x:Name="AbortButton" DockPanel.Dock="Right" Content="Abort" Width="90"
                        Click="Abort_Click" IsEnabled="False" Margin="8,0,0,0" />
                <TextBlock x:Name="ProgressLabel" DockPanel.Dock="Right" Text="Idle" Width="70"
                           VerticalAlignment="Center" Margin="8,0,0,0" TextAlignment="Right" />
                <ProgressBar x:Name="FfmpegProgressBar" Height="18" Minimum="0" Maximum="100" Value="0" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
