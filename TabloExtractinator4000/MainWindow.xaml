<Window x:Class="TabloExtractinator4000.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TabloExtractinator4000.ViewModels"
        xmlns:conv="clr-namespace:TabloExtractinator4000.Converters"
        mc:Ignorable="d"
        Title="{Binding AppVersion, StringFormat='Tablo Extractinator 4000  {0}'}"
        Icon="pack://application:,,,/app.ico"
        Height="740" Width="1100" MinHeight="560" MinWidth="860"
        Background="#1E1E1E"
        d:DataContext="{d:DesignInstance vm:MainViewModel}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:GroupBackgroundConverter x:Key="GroupBgConverter"/>

        <!-- ── ScrollBar sub-element styles ── -->
        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"             Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#686868" CornerRadius="3" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#9E9E9E"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#B8B8B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollBarPageStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop"  Value="False"/>
            <Setter Property="Focusable"  Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ScrollBar (no arrow buttons, VS Code style) ── -->
        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle"  Value="True"/>
            <Setter Property="SnapsToDevicePixels"    Value="True"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width"    Value="12"/>
                    <Setter Property="MinWidth" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="#2D2D2D">
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageStyle}"
                                                          Command="ScrollBar.PageUpCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageStyle}"
                                                          Command="ScrollBar.PageDownCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height"    Value="12"/>
                    <Setter Property="MinHeight" Value="12"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Border Background="#2D2D2D">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageStyle}"
                                                          Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollBarPageStyle}"
                                                          Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Dark CheckBox ── -->
        <Style TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle"     Value="True"/>
            <Setter Property="Foreground"                Value="#D4D4D4"/>
            <Setter Property="VerticalContentAlignment"  Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <BulletDecorator Background="Transparent">
                            <BulletDecorator.Bullet>
                                <Border x:Name="Box" Width="14" Height="14"
                                        Background="#3C3C3C" BorderBrush="#707070"
                                        BorderThickness="1" CornerRadius="2">
                                    <Path x:Name="Check"
                                          Data="M 2,7 L 5,11 L 12,3"
                                          Stroke="White" StrokeThickness="1.5"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Visibility="Collapsed"/>
                                </Border>
                            </BulletDecorator.Bullet>
                            <ContentPresenter Margin="4,0,0,0"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"/>
                        </BulletDecorator>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box"   Property="Background"  Value="#0078D4"/>
                                <Setter TargetName="Box"   Property="BorderBrush" Value="#0078D4"/>
                                <Setter TargetName="Check" Property="Visibility"  Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#9CDCFE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Global implicit dark styles ── -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D4D4D4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#D4D4D4"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"     Value="#3C3C3C"/>
            <Setter Property="Foreground"     Value="#D4D4D4"/>
            <Setter Property="BorderBrush"    Value="#5A5A5A"/>
            <Setter Property="CaretBrush"     Value="#D4D4D4"/>
            <Setter Property="SelectionBrush" Value="#094771"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background"  Value="#3C3C3C"/>
            <Setter Property="Foreground"  Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background"  Value="#3C3C3C"/>
            <Setter Property="Foreground"  Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Background"  Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels"   Value="True"/>
            <Setter Property="Foreground"            Value="#AAAAAA"/>
            <Setter Property="Padding"               Value="12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="#2D2D2D"
                                BorderBrush="#3F3F46" BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0" Margin="0,0,2,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"   Value="#1E1E1E"/>
                                <Setter TargetName="TabBorder" Property="BorderBrush"  Value="#3F3F46"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBorder" Property="Background" Value="#3A3A3A"/>
                                <Setter Property="Foreground" Value="#D4D4D4"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ContextMenu">
            <Setter Property="Background"  Value="#2D2D2D"/>
            <Setter Property="Foreground"  Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#5A5A5A"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="12,5,16,5">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Separator">
            <Setter Property="Background" Value="#5A5A5A"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#1E1E1E"/>
            <Setter Property="Foreground"               Value="#D4D4D4"/>
            <Setter Property="BorderBrush"              Value="#3F3F46"/>
            <Setter Property="RowBackground"            Value="#1E1E1E"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#3F3F46"/>
            <Setter Property="VerticalGridLinesBrush"   Value="Transparent"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"  Value="#252526"/>
            <Setter Property="Foreground"  Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
            <Setter Property="Padding"     Value="4,3"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Named styles ── -->
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#9CDCFE"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>
        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="BorderBrush"     Value="#3F3F46"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="4"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="Margin"          Value="0,0,0,8"/>
            <Setter Property="Background"      Value="#252526"/>
        </Style>
        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#141414" Padding="8,4"
                BorderBrush="#3F3F46" BorderThickness="0,1,0,0">
            <DockPanel>
                <ProgressBar DockPanel.Dock="Right" IsIndeterminate="{Binding IsBusy}"
                             Width="120" Height="10" Margin="8,0,0,0"
                             Foreground="#0078D4" Background="#3C3C3C"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#D4D4D4" VerticalAlignment="Center"
                           ToolTip="{Binding ParseErrorDetails}"/>
            </DockPanel>
        </Border>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="440"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="252" MinWidth="180"/>
            </Grid.ColumnDefinitions>
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch" Background="#3F3F46" Cursor="SizeWE"/>

            <!-- ============================================================
                 LEFT: TabControl  (Recordings | Settings)
            ============================================================ -->
            <TabControl Grid.Column="0" Margin="0,0,4,0" x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged">

                <!-- ── Tab 1: Recordings ── -->
                <TabItem Header="📺  Recordings">
                    <DockPanel Background="#1E1E1E">

                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Padding="0,4,0,6"
                                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                                Background="#252526">
                            <DockPanel LastChildFill="False">
                                <Button Content="↺  Load Recordings" Command="{Binding LoadRecordingsCommand}"
                                        Padding="10,4" Margin="0,0,6,0"/>
                                <Button Content="✓ All"  Command="{Binding SelectAllCommand}"  Padding="6,4" Margin="0,0,4,0"/>
                                <Button Content="✗ None" Command="{Binding SelectNoneCommand}" Padding="6,4"/>

                                <!-- Delete gate -->
                                <Border DockPanel.Dock="Right"
                                        Background="#3A2500" BorderBrush="#7A5000" BorderThickness="1"
                                        CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                                    <CheckBox IsChecked="{Binding DeleteEnabled}" VerticalAlignment="Center">
                                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="#FFB74D">
                                            <Run Text="⚠ Delete after extraction"/>
                                        </TextBlock>
                                    </CheckBox>
                                </Border>
                                <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                                           DockPanel.Dock="Right" VerticalAlignment="Center"
                                           Foreground="#888888"/>
                                <Border DockPanel.Dock="Right"
                                        Background="#252526" BorderBrush="#3F3F46" BorderThickness="1"
                                        CornerRadius="3" Padding="6,1" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding AppVersion}"
                                               Foreground="#9CDCFE" FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding DeviceLabel}" DockPanel.Dock="Right"
                                           VerticalAlignment="Center" Foreground="#4FC3F7"
                                           FontSize="11" Margin="0,0,8,0"/>
                            </DockPanel>
                        </Border>

                        <!-- ffmpeg warning banner -->
                        <Border DockPanel.Dock="Top"
                                Background="#3A2000" BorderBrush="#7A4400" BorderThickness="0,0,0,1"
                                Padding="8,4"
                                Visibility="{Binding FfmpegWarning, Converter={StaticResource BoolToVis},
                                             FallbackValue=Collapsed}">
                            <TextBlock Text="{Binding FfmpegWarning}" Foreground="#FFB74D"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Recordings DataGrid -->
                        <DataGrid x:Name="RecordingsGrid"
                                  ItemsSource="{Binding RecordingsView}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  SelectionMode="Extended"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="22" FontSize="12"
                                  VirtualizingPanel.IsVirtualizing="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"                      Color="#094771"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"                  Color="White"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"                        Color="#2D3F50"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"                    Color="#D4D4D4"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}"     Color="#2D3F50"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#D4D4D4"/>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="#1E1E1E"/>
                                    <Setter Property="Foreground" Value="#D4D4D4"/>
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                    <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="▶  Play"
                                                          Command="{Binding PlacementTarget.Tag.PlayRecordingCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="ℹ  Details"
                                                          Command="{Binding PlacementTarget.Tag.ShowDetailsCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <MenuItem Header="➕  Add to Extraction Queue"
                                                          Command="{Binding PlacementTarget.Tag.AddToExtractionCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                <Separator/>
                                                <MenuItem Header="🗑  Delete from Tablo"
                                                          Foreground="#EF5350"
                                                          Command="{Binding PlacementTarget.Tag.DeleteRecordingCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                                             RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RecordingType}" Value="Episode">
                                            <Setter Property="Background" Value="#1A2535"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecordingType}" Value="Movie">
                                            <Setter Property="Background" Value="#1A2B1A"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding RecordingType}" Value="Sport">
                                            <Setter Property="Background" Value="#2A2518"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <!-- Group headers -->
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Expander IsExpanded="False"
                                                                  Background="{Binding Converter={StaticResource GroupBgConverter}}"
                                                                  BorderBrush="#3F3F46"
                                                                  BorderThickness="0,0,0,1"
                                                                  Foreground="#D4D4D4">
                                                            <Expander.Header>
                                                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                    <CheckBox VerticalAlignment="Center"
                                                                              Margin="0,0,8,0"
                                                                              Tag="{Binding}"
                                                                              Checked="GroupCheckBox_Changed"
                                                                              Unchecked="GroupCheckBox_Changed"/>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="#D4D4D4"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0})'}"
                                                                               Foreground="#888888" FontSize="11"
                                                                               VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Expander.Header>
                                                            <ItemsPresenter/>
                                                        </Expander>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="28" CanUserSort="False"
                                                        CanUserResize="False" CanUserReorder="False">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader">
                                            <Setter Property="Background"      Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate><TextBlock/></DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="" Width="24"
                                                        CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Checked="Recording_SelectionChanged"
                                                      Unchecked="Recording_SelectionChanged"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Episode"  Binding="{Binding EpisodeTitle}"  Width="*"   IsReadOnly="True" MinWidth="120"/>
                                <DataGridTextColumn Header="S/E"      Binding="{Binding SeasonEpisode}" Width="62"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Aired"    Binding="{Binding AiredAt}"       Width="88"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration}"      Width="62"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Size"     Binding="{Binding SizeMb}"        Width="72"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Network"  Binding="{Binding NetworkName}"   Width="72"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="Ch"       Binding="{Binding Channel}"       Width="40"  IsReadOnly="True"/>
                                <DataGridTextColumn Header="State"    Binding="{Binding State}"         Width="66"  IsReadOnly="True"/>
                                <DataGridTemplateColumn Header="" Width="30" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="▶" FontSize="11" Padding="2,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#4FC3F7"
                                                    ToolTip="Play"
                                                    Command="{Binding DataContext.PlayRecordingCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="30" CanUserSort="False" CanUserResize="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="🗑" FontSize="11" Padding="2,0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#EF5350"
                                                    ToolTip="Delete from Tablo"
                                                    Command="{Binding DataContext.DeleteRecordingCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                    </DockPanel>
                </TabItem>

                <!-- ── Tab 2: Guide ── -->
                <TabItem Header="📡  Guide" x:Name="GuideTab">
                    <DockPanel Background="#1E1E1E">

                        <!-- Toolbar -->
                        <Border DockPanel.Dock="Top" Padding="6,4,6,5"
                                BorderBrush="#3F3F46" BorderThickness="0,0,0,1"
                                Background="#252526">
                            <DockPanel>
                                <ProgressBar DockPanel.Dock="Right" IsIndeterminate="{Binding IsLoading}"
                                             Width="100" Height="8" Margin="8,0,0,0" VerticalAlignment="Center"
                                             Foreground="#0078D4" Background="#3C3C3C"
                                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                                <Button Content="↺  Refresh" Command="{Binding LoadGuideCommand}"
                                        Padding="10,4" Margin="0,0,6,0"/>
                                <Button Content="⏱ Now" Command="{Binding ScrollToNowCommand}"
                                        Padding="8,4" Margin="0,0,12,0"/>
                                <!-- Color legend -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Border Width="10" Height="10" Background="#1A3A5C" BorderBrush="#4FC3F7" BorderThickness="1" Margin="0,0,3,0"/>
                                    <TextBlock Text="On Now" Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Width="10" Height="10" Background="#1D4A2A" BorderBrush="#2EA043" BorderThickness="1" Margin="0,0,3,0"/>
                                    <TextBlock Text="Scheduled" Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Width="10" Height="10" Background="#2D2A4A" BorderBrush="#3F3F46" BorderThickness="1" Margin="0,0,3,0"/>
                                    <TextBlock Text="Movie" Foreground="#888" FontSize="10" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Border Width="10" Height="10" Background="#2A3D4A" BorderBrush="#3F3F46" BorderThickness="1" Margin="0,0,3,0"/>
                                    <TextBlock Text="Sport" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="{Binding StatusText}"
                                           VerticalAlignment="Center" Foreground="#888888" FontSize="11"/>
                            </DockPanel>
                        </Border>

                        <!-- Guide grid: day header + time header + channel rows -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20"/>  <!-- day labels -->
                                <RowDefinition Height="24"/>  <!-- time labels -->
                                <RowDefinition Height="*"/>   <!-- channel rows -->
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Top-left corner (spans both header rows) -->
                            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Background="#1A1A1A"
                                    BorderBrush="#3F3F46" BorderThickness="0,0,1,1"/>

                            <!-- Day header (scrolls horizontally in sync) -->
                            <ScrollViewer Grid.Row="0" Grid.Column="1"
                                          x:Name="GuideDayScroll"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="#141414">
                                <Canvas Height="20" Width="{Binding CanvasWidth}">
                                    <ItemsControl ItemsSource="{Binding DayHeaders}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top"  Value="0"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#555" BorderThickness="1,0,0,1"
                                                        Width="{Binding Width}" Height="20"
                                                        Background="#1E1E2E">
                                                    <TextBlock Text="{Binding Label}" Foreground="#C0A060"
                                                               FontSize="10" FontWeight="SemiBold"
                                                               Padding="6,3,0,0" TextTrimming="CharacterEllipsis"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </ScrollViewer>

                            <!-- Time header -->
                            <ScrollViewer Grid.Row="1" Grid.Column="1"
                                          x:Name="GuideHeaderScroll"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          Background="#1A1A1A">
                                <Canvas Height="24" Width="{Binding CanvasWidth}">
                                    <ItemsControl ItemsSource="{Binding TimeHeaders}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><Canvas/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                <Setter Property="Canvas.Top"  Value="0"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="#3F3F46" BorderThickness="1,0,0,1" Width="180" Height="24">
                                                    <TextBlock Text="{Binding Label}" Foreground="#9CDCFE" FontSize="10" Padding="4,4,0,0"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>
                            </ScrollViewer>

                            <!-- Channel label column -->
                            <ScrollViewer Grid.Row="2" Grid.Column="0"
                                          x:Name="GuideChannelScroll"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Hidden"
                                          ScrollChanged="GuideChannelScroll_ScrollChanged"
                                          Background="#1A1A1A">
                                <ItemsControl ItemsSource="{Binding Rows}" x:Name="GuideChannelList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="52" BorderBrush="#3F3F46" BorderThickness="0,0,1,1"
                                                    Background="#1A1A1A" Padding="6,0" Cursor="Hand"
                                                    MouseLeftButtonDown="ChannelLabel_MouseLeftButtonDown">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="▶  Watch Live"
                                                                  CommandParameter="{Binding}"
                                                                  Click="ChannelWatchLive_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <TextBlock VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#D4D4D4" TextTrimming="CharacterEllipsis"
                                                           Text="{Binding Channel.Label}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Program cells canvas -->
                            <ScrollViewer Grid.Row="2" Grid.Column="1"
                                          x:Name="GuideBodyScroll"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          ScrollChanged="GuideBodyScroll_ScrollChanged"
                                          Background="#1E1E1E">
                                <ItemsControl ItemsSource="{Binding Rows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Vertical"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Canvas Height="52" Width="{Binding DataContext.CanvasWidth,
                                                        RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><Canvas/></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                                            <Setter Property="Canvas.Top"  Value="0"/>
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="{Binding Width}" Height="52"
                                                                    Background="{Binding Background}"
                                                                    BorderBrush="{Binding BorderColor}"
                                                                    BorderThickness="1,0,0,1"
                                                                    ToolTip="{Binding Tooltip}"
                                                                    Cursor="Hand"
                                                                    MouseLeftButtonDown="AiringCell_MouseLeftButtonDown">
                                                                <Border.ContextMenu>
                                                                    <ContextMenu Opened="AiringContextMenu_Opened">
                                                                        <MenuItem x:Name="MenuWatchLive"
                                                                                  Header="▶  Watch Live"
                                                                                  Click="AiringWatchLive_Click"/>
                                                                        <MenuItem x:Name="MenuSchedule"
                                                                                  Header="📅  Schedule Recording"
                                                                                  Click="AiringSchedule_Click"/>
                                                                        <MenuItem x:Name="MenuUnschedule"
                                                                                  Header="✕  Cancel This Recording"
                                                                                  Foreground="#EF9090"
                                                                                  Click="AiringUnschedule_Click"/>
                                                                        <Separator/>
                                                                        <MenuItem x:Name="MenuAiringDetails"
                                                                                  Header="ℹ  Details"
                                                                                  Click="AiringDetails_Click"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="#D4D4D4" FontSize="12"
                                                                           Padding="4,4,4,2"
                                                                           TextWrapping="Wrap"
                                                                           VerticalAlignment="Top"
                                                                           IsHitTestVisible="False"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Canvas>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </DockPanel>
                </TabItem>

                <!-- ── Tab 3: Settings ── -->
                <TabItem Header="⚙  Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#1E1E1E">
                        <StackPanel Margin="8,8,8,4">

                            <!-- Tablo Account -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Tablo Account" Style="{StaticResource HeaderText}"/>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="64"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Label Grid.Row="0" Grid.Column="0" Content="Email:"    VerticalAlignment="Center" Padding="0"/>
                                        <TextBox Grid.Row="0" Grid.Column="1"
                                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="4,0,0,0" VerticalContentAlignment="Center" Height="26"/>
                                        <Label Grid.Row="0" Grid.Column="2" Content="Password:" VerticalAlignment="Center" Padding="4,0,0,0"/>
                                        <PasswordBox Grid.Row="0" Grid.Column="3" x:Name="PasswordBox"
                                                     Margin="4,0,0,0" Height="26"
                                                     PasswordChanged="PasswordBox_PasswordChanged"/>
                                        <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                                Content="Reconnect to Tablo" Command="{Binding ConnectCommand}"
                                                Padding="12,4" Margin="0,6,0,0" HorizontalAlignment="Left"/>
                                    </Grid>
                                    <TextBlock Text="{Binding DeviceLabel}"  Margin="0,6,0,0" Foreground="#4FC3F7" FontSize="11"/>
                                    <TextBlock Text="{Binding StorageLabel}" Foreground="#888888" FontSize="11"/>
                                </StackPanel>
                            </Border>

                            <!-- Output Folders -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Output Folders" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Text="Episode output folder:" Style="{StaticResource FormLabel}"/>
                                    <DockPanel Margin="0,0,0,8">
                                        <Button DockPanel.Dock="Right" Content="…" Padding="6,2" Margin="4,0,0,0"
                                                Command="{Binding BrowseOutputFolderCommand}"/>
                                        <TextBox Text="{Binding OutputFolder}" FontSize="11" VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                    <TextBlock Text="Movie output folder:" Style="{StaticResource FormLabel}"/>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="…" Padding="6,2" Margin="4,0,0,0"
                                                Command="{Binding BrowseMovieFolderCommand}"/>
                                        <TextBox Text="{Binding MovieOutputFolder}" FontSize="11" VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- Filename Templates -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Filename Templates" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Text="Episode:" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding EpisodeTemplate, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" Margin="0,0,0,8" FontFamily="Consolas"/>
                                    <TextBlock Text="Movie:" Style="{StaticResource FormLabel}"/>
                                    <TextBox Text="{Binding MovieTemplate, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="11" FontFamily="Consolas"/>
                                </StackPanel>
                            </Border>

                            <!-- Parallel Downloads -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Parallel Downloads" Style="{StaticResource HeaderText}"/>
                                    <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,6" TextWrapping="Wrap">
                                        Number of simultaneous extractions. Set to 2 if your Tablo's network
                                        can support it (100 Mb wired recommended).
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Simultaneous downloads:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                        <TextBox Text="{Binding MaxParallelDownloads, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="40" TextAlignment="Center" FontFamily="Consolas" FontSize="13"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Media Player -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="Media Player" Style="{StaticResource HeaderText}"/>
                                    <TextBlock Text="Path to player exe — used for the ▶ Play button (VLC, mpv, etc.):" Style="{StaticResource FormLabel}"/>
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="…" Padding="6,2" Margin="4,0,0,0"
                                                Command="{Binding BrowseVlcPathCommand}"/>
                                        <TextBox Text="{Binding VlcPath, UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="11" FontFamily="Consolas" VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>
                            </Border>

                            <!-- ffmpeg Options -->
                            <Border Style="{StaticResource SectionBorder}">
                                <StackPanel>
                                    <TextBlock Text="ffmpeg Encoding Options" Style="{StaticResource HeaderText}"/>
                                    <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,4" TextWrapping="Wrap">
                                        Arguments inserted between <Run FontFamily="Consolas" Foreground="#4FC3F7">-i &lt;url&gt;</Run>
                                        and the output file. The app always appends
                                        <Run FontFamily="Consolas" Foreground="#888888">-movflags +faststart -y</Run>
                                        and manages input/output paths automatically.
                                    </TextBlock>
                                    <TextBox Text="{Binding FfmpegExtraArgs, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Consolas" FontSize="12"
                                             TextWrapping="Wrap" AcceptsReturn="False"
                                             MinHeight="52" VerticalContentAlignment="Top"
                                             Padding="4"/>
                                    <TextBlock FontSize="10" Foreground="#666666" Margin="0,4,0,0" TextWrapping="Wrap">
                                        Examples: <Run FontFamily="Consolas">-c:v libx264 -preset fast -crf 23 -c:a aac</Run>
                                        · <Run FontFamily="Consolas">-c copy</Run>
                                        · <Run FontFamily="Consolas">-b:v 4M -c:v libx264 -c:a copy</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Save -->
                            <Button Content="💾  Save Settings" Command="{Binding SaveSettingsCommand}"
                                    Padding="14,7" HorizontalAlignment="Left"
                                    Background="#0078D4" Foreground="White" FontWeight="SemiBold"
                                    BorderBrush="#005A9E"/>

                            <!-- About -->
                            <Border Style="{StaticResource SectionBorder}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="About" Style="{StaticResource HeaderText}"/>
                                    <TextBlock FontSize="11" Foreground="#888888" Margin="0,0,0,6" TextWrapping="Wrap">
                                        Tablo Extractinator 4000 — extracts recordings from a Tablo 4th-generation DVR.
                                    </TextBlock>
                                    <Button Content="ℹ  About This App…"
                                            Padding="12,5" HorizontalAlignment="Left"
                                            Click="AboutButton_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- ============================================================
                 RIGHT: Export panel (always visible)
            ============================================================ -->
            <DockPanel Grid.Column="2">

                <!-- Export actions -->
                <Border DockPanel.Dock="Top" Style="{StaticResource SectionBorder}">
                    <StackPanel>
                        <Button Content="▶  Start Extraction"
                                Command="{Binding ExportSelectedCommand}"
                                Background="#0078D4" Foreground="White"
                                BorderBrush="#005A9E"
                                FontWeight="SemiBold" Padding="0,9" FontSize="13"/>
                        <Button Content="⬛  Abort Extraction"
                                Command="{Binding CancelExportSelectedCommand}"
                                Background="#C62828" Foreground="White"
                                BorderBrush="#8B0000"
                                FontWeight="SemiBold" Padding="0,7" FontSize="12"
                                Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </Border>

                <!-- Export progress -->
                <Border Style="{StaticResource SectionBorder}">
                    <DockPanel>
                        <!-- Elapsed / remaining summary — remaining is a rough guess -->
                        <Border DockPanel.Dock="Top"
                                Background="#252526" BorderBrush="#3F3F46" BorderThickness="1"
                                CornerRadius="3" Padding="8,5" Margin="0,0,0,8">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="Elapsed:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalElapsedText}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#D4D4D4" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Remaining:" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalRemainingText}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="#4FC3F7" Margin="4,0,0,0" VerticalAlignment="Center"
                                               ToolTip="Rough guess — based on current progress and the recordings' own runtime."/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ExportJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#3F3F46" BorderThickness="0,0,0,1" Padding="0,5">
                                            <StackPanel>
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            Content="{Binding CancelButtonLabel}"
                                                            Command="{Binding CancelCommand}"
                                                            Padding="6,1" FontSize="9" Margin="4,0,0,0"
                                                            Background="#3C3C3C" Foreground="#EF9090" BorderBrush="#5A5A5A"/>
                                                    <CheckBox DockPanel.Dock="Left"
                                                              IsChecked="{Binding DeleteAfterExtraction}"
                                                              VerticalAlignment="Center" Margin="0,0,5,0"
                                                              ToolTip="Delete from Tablo after successful extraction"/>
                                                    <TextBlock Text="{Binding Title}" FontSize="11"
                                                               FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                               Foreground="#D4D4D4" VerticalAlignment="Center"/>
                                                </DockPanel>
                                                <ProgressBar Value="{Binding ProgressPct}" Maximum="100"
                                                             Height="7" Margin="0,3"
                                                             Foreground="#0078D4" Background="#3C3C3C"/>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding RateText}"
                                                               FontSize="10" Foreground="#4FC3F7" Margin="4,0,0,0"/>
                                                    <TextBlock Text="{Binding BytesText}" FontSize="10" Foreground="#888888"/>
                                                </DockPanel>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right" Text="{Binding ElapsedText}"
                                                               FontSize="10" Foreground="#666666" Margin="4,0,0,0"/>
                                                    <TextBlock Text="{Binding TimeRemainingText}" FontSize="10"
                                                               Foreground="#888888" Margin="0,1,0,0"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Status}" FontSize="10"
                                                           Foreground="#666666" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

            </DockPanel>

        </Grid>
    </DockPanel>
</Window>
